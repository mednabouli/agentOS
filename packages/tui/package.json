{
  "name": "@agentos/tui",
  "version": "0.2.0",
  "description": "AgentOS Ink terminal UI — 4-pane layout with phase-gate approval",
  "license": "MIT",
  "author": "Med Nabouli",
  "homepage": "https://github.com/med-nabouli/agentOS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/med-nabouli/agentOS.git",
    "directory": "packages/tui"
  },
  "bugs": {
    "url": "https://github.com/med-nabouli/agentOS/issues"
  },
  "keywords": [
    "claude",
    "anthropic",
    "ai-agents",
    "terminal",
    "tui",
    "ink",
    "agentos"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@agentos/core": "workspace:*",
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.28",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
