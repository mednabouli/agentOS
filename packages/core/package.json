{
  "name": "@agentos/core",
  "version": "0.1.0",
  "description": "AgentOS orchestration engine — pure TypeScript, zero UI deps",
  "license": "MIT",
  "author": "Med Nabouli",
  "homepage": "https://github.com/med-nabouli/agentOS#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/med-nabouli/agentOS.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/med-nabouli/agentOS/issues"
  },
  "keywords": [
    "claude",
    "anthropic",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "llm",
    "agentos"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@supabase/supabase-js": "^2.103.3",
    "better-sqlite3": "^12.0.0",
    "eventemitter3": "^5.0.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
