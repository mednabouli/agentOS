{
  "name": "@agentos/core",
  "version": "0.0.1",
  "description": "AgentOS orchestration engine — pure TypeScript, zero UI deps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "@supabase/supabase-js": "^2.49.0",
    "better-sqlite3": "^11.9.0",
    "eventemitter3": "^5.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
