{
  "name": "agentos",
  "version": "1.0.0",
  "description": "AgentOS CLI — npx agentos entry point",
  "type": "module",
  "bin": {
    "agentos": "./dist/bin/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@agentos/core": "workspace:*",
    "@agentos/tui": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
