{
  "name": "agentos",
  "private": true,
  "version": "0.0.1",
  "description": "Multi-interface AI agent orchestration platform built natively for Claude",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "turbo": "latest",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "turbo",
      "@esbuild/darwin-arm64"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0"
  }
}
